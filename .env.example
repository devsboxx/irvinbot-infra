# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT — debe ser idéntico en auth, chat, docs y gateway
SECRET_KEY=change-this-to-a-long-random-string

# LLM
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_MODEL=                      # vacío = usa el default del provider

# ChromaDB
CHROMA_COLLECTION=thesis_docs

# Docs service
MAX_FILE_SIZE_MB=50
