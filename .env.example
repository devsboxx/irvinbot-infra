# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=24889173

# JWT — debe ser idéntico en auth, chat, docs y gateway
SECRET_KEY=c5e40cff-f86d-4efc-b389-342344ffd037

# ── LLM ───────────────────────────────────────────────────────────────────────
# Opciones: ollama | groq | openai | anthropic
LLM_PROVIDER=ollama
# Modelo. Vacío = default del proveedor:
#   ollama → llama3.2  |  groq → llama-3.3-70b-versatile
#   openai → gpt-4o    |  anthropic → claude-sonnet-4-6
LLM_MODEL=

# ── Embeddings ────────────────────────────────────────────────────────────────
# Opciones: ollama | openai
EMBEDDING_PROVIDER=ollama
# Modelo. Vacío = default:  ollama → nomic-embed-text  |  openai → text-embedding-3-small
EMBEDDING_MODEL=

# ── Credenciales (solo la del proveedor activo) ───────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# Si los contenedores de chat/docs están en Docker y Ollama corre en el host:
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_COLLECTION=thesis_docs

# Docs service
MAX_FILE_SIZE_MB=50
