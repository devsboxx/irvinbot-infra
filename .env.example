# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esto-por-tu-password

# ── JWT — CRÍTICO: debe ser idéntico en auth, chat, docs y gateway ────────────
# Genera uno con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-secreto-igual-en-todos-los-servicios
ALGORITHM=HS256

# ── LLM (usado por el servicio de chat) ───────────────────────────────────────
# Opciones: ollama | groq | openai | anthropic
# - ollama:    gratis, corre en tu Mac. Requiere `ollama serve` + modelo descargado
# - groq:      gratis (tier gratuito). Clave gratis en console.groq.com
# - openai:    pago
# - anthropic: pago
LLM_PROVIDER=ollama

# Modelo. Vacío = default del proveedor:
#   ollama → llama3.2  |  groq → llama-3.3-70b-versatile
#   openai → gpt-4o    |  anthropic → claude-sonnet-4-6
LLM_MODEL=

# ── Embeddings (usado por chat y docs para RAG) ───────────────────────────────
# Opciones: ollama | openai
EMBEDDING_PROVIDER=ollama

# Modelo. Vacío = default:
#   ollama → nomic-embed-text  |  openai → text-embedding-3-small
EMBEDDING_MODEL=

# ── Credenciales (rellena solo la del proveedor activo) ───────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Ollama (si LLM_PROVIDER=ollama o EMBEDDING_PROVIDER=ollama) ───────────────
# Los contenedores Docker en Mac/Windows acceden al host así:
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Si corres los servicios directamente (sin Docker), usa:
# OLLAMA_BASE_URL=http://localhost:11434

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_COLLECTION=thesis_docs

# ── Docs service ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
